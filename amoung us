/**
 * Local Multiplayer Social Deduction Game Logic (Among Us Clone)
 * 
 * Requirements:
 * - Roles: Crewmate, Impostor
 * - Task list for Crewmates
 * - Kill cooldown for Impostor
 * - Meeting function for voting (most votes gets ejected)
 * - Win Conditions:
 *      1. Impostors win if Impostor Count >= Crewmate Count
 *      2. Crewmates win if all tasks are done OR all Impostors are voted out
 */

class Game {
    constructor(playerNames) {
        this.players = playerNames.map(name => ({
            name: name,
            role: 'Crewmate', // Default role
            isAlive: true,
            tasks: [],
            killCooldown: 0
        }));
        this.totalTasks = 0;
        this.completedTasks = 0;
        this.isActive = true;
    }

    // Initialize game with a specific number of impostors
    start(impostorCount = 1) {
        if (impostorCount >= this.players.length) {
            console.log("Error: Too many impostors for the player count.");
            return;
        }

        // 1. Assign Roles
        let assignedImpostors = 0;
        while (assignedImpostors < impostorCount) {
            const randomIndex = Math.floor(Math.random() * this.players.length);
            if (this.players[randomIndex].role !== 'Impostor') {
                this.players[randomIndex].role = 'Impostor';
                assignedImpostors++;
            }
        }

        // 2. Assign Tasks to Crewmates
        const possibleTasks = ["Fix Wiring", "Swipe Card", "Download Data", "Clean Filter", "Empty Garbage"];
        this.players.forEach(player => {
            if (player.role === 'Crewmate') {
                // Assign 3 random tasks
                player.tasks = possibleTasks.sort(() => 0.5 - Math.random()).slice(0, 3);
                this.totalTasks += player.tasks.length;
            } else {
                // Impostors have a kill cooldown init
                player.killCooldown = 10; 
            }
        });

        console.log("Game Started!");
        this.printStatus();
    }

    printStatus() {
        console.log("\n--- Current Status ---");
        this.players.forEach(p => {
            const taskStr = p.role === 'Crewmate' ? `Tasks: [${p.tasks.join(", ")}]` : "Impostor";
            console.log(`${p.name} [${p.isAlive ? 'Alive' : 'Dead'}] - ${p.role} | ${taskStr}`);
        });
        console.log(`Global Tasks Completed: ${this.completedTasks}/${this.totalTasks}`);
    }

    // Crewmate Action: Complete Task
    completeTask(playerName, taskName) {
        if (!this.isActive) return;

        const player = this.players.find(p => p.name === playerName);
        if (!player || !player.isAlive || player.role !== 'Crewmate') {
            console.log(`${playerName} cannot complete tasks.`);
            return;
        }

        const taskIndex = player.tasks.indexOf(taskName);
        if (taskIndex > -1) {
            player.tasks.splice(taskIndex, 1);
            this.completedTasks++;
            console.log(`${playerName} completed task: ${taskName}.`);
            this.checkWinCondition();
        } else {
            console.log(`${playerName} does not have the task: ${taskName}`);
        }
    }

    // Impostor Action: Kill
    impostorKill(impostorName, targetName) {
        if (!this.isActive) return;

        const impostor = this.players.find(p => p.name === impostorName);
        const target = this.players.find(p => p.name === targetName);

        if (!impostor || impostor.role !== 'Impostor' || !impostor.isAlive) {
            console.log(`Invalid killer request from ${impostorName}.`);
            return;
        }
        if (!target || !target.isAlive) {
            console.log(`Invalid target ${targetName}.`);
            return;
        }
        if (impostor.killCooldown > 0) {
            console.log(`${impostorName} is on kill cooldown! Wait ${impostor.killCooldown}s.`);
            return;
        }

        target.isAlive = false;
        console.log(`PEW! ${impostorName} killed ${targetName}!`);
        
        // Reset cooldown
        impostor.killCooldown = 20; 
        
        this.checkWinCondition();
    }

    // Cooldown ticker (simulation helper)
    tickCooldowns(seconds) {
        this.players.forEach(p => {
            if (p.role === 'Impostor' && p.killCooldown > 0) {
                p.killCooldown = Math.max(0, p.killCooldown - seconds);
            }
        });
    }

    // Meeting Function: Voting
    // votesMap format: { "VoterName": "TargetName" (or "Skip") }
    callMeeting(votesMap) {
        if (!this.isActive) return;
        console.log("\n--- MEETING CALLED ---");

        const voteCounts = { "Skip": 0 };
        
        for (const [voterName, targetName] of Object.entries(votesMap)) {
            const voter = this.players.find(p => p.name === voterName);
            // Only alive players can vote
            if (voter && voter.isAlive) {
                if (targetName === "Skip") {
                    voteCounts["Skip"]++;
                } else {
                    // Check if target is valid
                    const target = this.players.find(p => p.name === targetName);
                    if (target) {
                        voteCounts[targetName] = (voteCounts[targetName] || 0) + 1;
                    }
                }
            }
        }

        console.log("Votes:", voteCounts);

        // Find result
        let maxVotes = 0;
        let candidates = [];
        for (const [candidate, count] of Object.entries(voteCounts)) {
            if (count > maxVotes) {
                maxVotes = count;
                candidates = [candidate];
            } else if (count === maxVotes) {
                candidates.push(candidate);
            }
        }

        if (candidates.length === 1 && candidates[0] !== "Skip") {
            const ejectedName = candidates[0];
            const ejectedPlayer = this.players.find(p => p.name === ejectedName);
            if (ejectedPlayer) {
                ejectedPlayer.isAlive = false;
                console.log(`${ejectedName} was ejected.`);
                
                // Reveal role (optional setting)
                console.log(`${ejectedName} was ${ejectedPlayer.role === 'Impostor' ? 'An Impostor' : 'Not An Impostor'}.`);
                
                this.checkWinCondition();
            }
        } else {
            console.log(`No one was ejected. (Result: ${candidates.join(" tied with ")} or Skipped)`);
        }
    }

    checkWinCondition() {
        const aliveImpostors = this.players.filter(p => p.role === 'Impostor' && p.isAlive).length;
        const aliveCrewmates = this.players.filter(p => p.role === 'Crewmate' && p.isAlive).length;

        if (aliveImpostors === 0) {
            console.log("\n>>> CREWMATES WIN! (All Impostors eliminated) <<<");
            this.isActive = false;
            return;
        }

        if (aliveImpostors >= aliveCrewmates) {
            console.log("\n>>> IMPOSTORS WIN! (Critical Sabotage or Outnumbered) <<<");
            this.isActive = false;
            return;
        }

        if (this.completedTasks >= this.totalTasks && this.totalTasks > 0) {
            console.log("\n>>> CREWMATES WIN! (All Tasks Completed) <<<");
            this.isActive = false;
            return;
        }
    }
}

// ==========================================
// EXAMPLE USAGE / SIMULATION
// ==========================================

console.log("Initializing Game Logic...");
const game = new Game(["Red", "Blue", "Green", "Yellow", "Pink"]);
game.start(1); // Start with 1 Impostor

// Helper to find who is who for the demo
const impostor = game.players.find(p => p.role === 'Impostor');
const crewmate = game.players.find(p => p.role === 'Crewmate');

console.log(`\n(Internal Info: ${impostor.name} is the Impostor)`);

// 1. Crewmate does a task
if (crewmate && crewmate.tasks.length > 0) {
    game.completeTask(crewmate.name, crewmate.tasks[0]);
}

// 2. Impostor tries to kill immediately (should fail due to cooldown)
console.log("\n-- Attempting immediate kill --");
game.impostorKill(impostor.name, crewmate.name);

// 3. Fast forward time
console.log("\n-- Waiting 10 seconds --");
game.tickCooldowns(10); 

// 4. Impostor kills a crewmate
console.log("\n-- Attempting kill after cooldown --");
// Find a target that isn't the impostor
const victim = game.players.find(p => p.name !== impostor.name && p.isAlive);
if (victim) {
    game.impostorKill(impostor.name, victim.name);
}

// 5. Meeting called
console.log("\n-- Body reported! Meeting called --");
const votes = {};
// Everyone blindly votes for 'Green' (just as an example)
game.players.forEach(p => {
    if (p.isAlive) votes[p.name] = "Green"; 
});
game.callMeeting(votes);
