# PickMyBinge environment variables
# Copy this file to `.env` and fill in the values. Never commit `.env`.

# --- Frontend (Vite — exposed to browser) ---
# Get a free TMDB API key at https://www.themoviedb.org/settings/api
# NOTE: VITE_ vars are embedded in the shipped bundle. Consider proxying
# via a serverless function if you need to keep the key secret.
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# --- Build-time / scripts (server side only) ---
# TMDB key used by scripts/generate-blog.js for blog content generation
TMDB_API_KEY=your_tmdb_api_key_here

# Groq API key for AI blog generation — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
